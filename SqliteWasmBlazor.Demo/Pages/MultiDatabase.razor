@page "/multidatabase"
@using Microsoft.EntityFrameworkCore
@using SqliteWasmBlazor.Models
@using SqliteWasmBlazor.Models.Models
@inject IDbContextFactory<TodoDbContext> TodoFactory
@inject IDbContextFactory<NoteDbContext> NoteFactory

<PageTitle>Multi-Database Demo</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Multi-Database Demo</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
    Two independent OPFS databases (TodoDb.db and NotesDb.db) running simultaneously in the same Web Worker.
    Notes can reference todos across databases via a loose Guid reference (no FK constraint).
</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.CheckBox" Class="mr-1" /> Todos (TodoDb.db)
            </MudText>

            <MudStack Row AlignItems="AlignItems.End" Class="mb-4">
                <MudTextField @bind-Value="_todoTitle" Label="Title" Variant="Variant.Outlined"
                              Immediate OnKeyDown="@OnTodoKeyDown" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTodo"
                           Disabled="@string.IsNullOrWhiteSpace(_todoTitle)">Add</MudButton>
            </MudStack>

            @if (_todos.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No todos yet.</MudText>
            }
            else
            {
                <MudList T="Todo" Dense>
                    @foreach (var todo in _todos)
                    {
                        var noteCount = _notes.Count(n => n.TodoId == todo.Id);
                        <MudListItem T="Todo">
                            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row AlignItems="AlignItems.Center">
                                    <MudCheckBox T="bool" Value="@todo.Completed"
                                                 ValueChanged="@(_ => ToggleTodo(todo))" Color="Color.Primary" />
                                    <MudText Style="@(todo.Completed ? "text-decoration: line-through" : "")">
                                        @todo.Title
                                    </MudText>
                                    @if (noteCount > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Color="Color.Secondary">
                                            @noteCount note(s)
                                        </MudChip>
                                    }
                                </MudStack>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteTodo(todo))" />
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                @_todos.Count item(s) in TodoDb.db
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Note" Class="mr-1" /> Notes (NotesDb.db)
            </MudText>

            <MudStack Spacing="2" Class="mb-4">
                <MudTextField @bind-Value="_noteTitle" Label="Title" Variant="Variant.Outlined" Immediate />
                <MudTextField @bind-Value="_noteContent" Label="Content" Variant="Variant.Outlined"
                              Lines="3" Immediate />
                <MudStack Row Spacing="2">
                    <MudSelect T="string" @bind-Value="_noteTag" Label="Tag" Variant="Variant.Outlined">
                        <MudSelectItem T="string" Value="@("")">None</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Work")">Work</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Personal")">Personal</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Idea")">Idea</MudSelectItem>
                    </MudSelect>
                    <MudSelect T="Guid?" @bind-Value="_noteTodoId" Label="Link to Todo" Variant="Variant.Outlined">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">No link</MudSelectItem>
                        @foreach (var todo in _todos)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)todo.Id)">@todo.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="AddNote"
                           Disabled="@(string.IsNullOrWhiteSpace(_noteTitle) || string.IsNullOrWhiteSpace(_noteContent))">
                    Add Note
                </MudButton>
            </MudStack>

            @if (_notes.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No notes yet.</MudText>
            }
            else
            {
                @foreach (var note in _notes)
                {
                    <MudCard Class="mb-2" Elevation="1">
                        <MudCardContent>
                            <MudStack Row AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle1">@note.Title</MudText>
                                    <MudText Typo="Typo.body2">@note.Content</MudText>
                                    <MudStack Row Spacing="2" Class="mt-1" AlignItems="AlignItems.Center">
                                        @if (!string.IsNullOrEmpty(note.Tag))
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Info">@note.Tag</MudChip>
                                        }
                                        @if (note.TodoId is not null)
                                        {
                                            var linkedTodo = _todos.FirstOrDefault(t => t.Id == note.TodoId);
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                     Color="Color.Primary"
                                                     Icon="@Icons.Material.Filled.Link">
                                                @(linkedTodo?.Title ?? "Deleted todo")
                                            </MudChip>
                                        }
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @note.CreatedAt.ToString("g")
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteNote(note))" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                @_notes.Count item(s) in NotesDb.db
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<Todo> _todos = new();
    private List<Note> _notes = new();
    private string _todoTitle = string.Empty;
    private string _noteTitle = string.Empty;
    private string _noteContent = string.Empty;
    private string _noteTag = string.Empty;
    private Guid? _noteTodoId;
    private Guid _defaultListId;

    protected override async Task OnInitializedAsync()
    {
        await using var todoContext = await TodoFactory.CreateDbContextAsync();
        var list = await todoContext.TodoLists.FirstOrDefaultAsync();
        if (list is null)
        {
            list = new SqliteWasmBlazor.Models.Models.TodoList
            {
                Id = Guid.NewGuid(),
                Title = "Multi-DB Demo",
                CreatedAt = DateTime.UtcNow
            };
            todoContext.TodoLists.Add(list);
            await todoContext.SaveChangesAsync();
        }
        _defaultListId = list.Id;

        await LoadData();
    }

    private async Task LoadData()
    {
        await using var todoContext = await TodoFactory.CreateDbContextAsync();
        _todos = await todoContext.Todos.OrderByDescending(t => t.Priority).ToListAsync();

        await using var noteContext = await NoteFactory.CreateDbContextAsync();
        _notes = await noteContext.Notes.OrderByDescending(n => n.CreatedAt).ToListAsync();
    }

    private async Task AddTodo()
    {
        if (string.IsNullOrWhiteSpace(_todoTitle))
        {
            return;
        }

        await using var ctx = await TodoFactory.CreateDbContextAsync();
        ctx.Todos.Add(new Todo
        {
            Id = Guid.NewGuid(),
            Title = _todoTitle,
            TodoListId = _defaultListId
        });
        await ctx.SaveChangesAsync();
        _todoTitle = string.Empty;
        await LoadData();
    }

    private async Task OnTodoKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddTodo();
        }
    }

    private async Task ToggleTodo(Todo todo)
    {
        await using var ctx = await TodoFactory.CreateDbContextAsync();
        var entity = await ctx.Todos.FindAsync(todo.Id);
        if (entity is not null)
        {
            entity.Completed = !entity.Completed;
            entity.CompletedAt = entity.Completed ? DateTime.UtcNow : null;
            await ctx.SaveChangesAsync();
        }
        await LoadData();
    }

    private async Task DeleteTodo(Todo todo)
    {
        await using var ctx = await TodoFactory.CreateDbContextAsync();
        var entity = await ctx.Todos.FindAsync(todo.Id);
        if (entity is not null)
        {
            ctx.Todos.Remove(entity);
            await ctx.SaveChangesAsync();
        }
        await LoadData();
    }

    private async Task AddNote()
    {
        if (string.IsNullOrWhiteSpace(_noteTitle) || string.IsNullOrWhiteSpace(_noteContent))
        {
            return;
        }

        await using var ctx = await NoteFactory.CreateDbContextAsync();
        ctx.Notes.Add(new Note
        {
            Id = Guid.NewGuid(),
            Title = _noteTitle,
            Content = _noteContent,
            Tag = string.IsNullOrWhiteSpace(_noteTag) ? null : _noteTag,
            TodoId = _noteTodoId,
            CreatedAt = DateTime.UtcNow
        });
        await ctx.SaveChangesAsync();
        _noteTitle = string.Empty;
        _noteContent = string.Empty;
        _noteTag = string.Empty;
        _noteTodoId = null;
        await LoadData();
    }

    private async Task DeleteNote(Note note)
    {
        await using var ctx = await NoteFactory.CreateDbContextAsync();
        var entity = await ctx.Notes.FindAsync(note.Id);
        if (entity is not null)
        {
            ctx.Notes.Remove(entity);
            await ctx.SaveChangesAsync();
        }
        await LoadData();
    }
}
