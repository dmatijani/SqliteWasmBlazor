@page "/database-import-export"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using System.Runtime.Versioning
@using SqliteWasmBlazor
@using SqliteWasmBlazor.Components.Interop
@using SqliteWasmBlazor.Models
@using SqliteWasmBlazor.Models.Extensions
@inject ISqliteWasmDatabaseService DatabaseService
@inject IDbContextFactory<TodoDbContext> DbContextFactory
@inject ISnackbar Snackbar
@inject ILogger<DatabaseImportExport> Logger

<PageTitle>Database Import/Export</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h5" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.SwapVert" Class="mr-1" />
        Raw Database Import/Export
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Export and import the raw TodoDb.db SQLite file directly from/to OPFS.
    </MudText>

    <MudPaper Elevation="2" Class="pa-4">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Class="mr-1" />
                TodoDb.db
            </MudText>

            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @if (_exists && _itemCount is not null)
                {
                    @($"{_itemCount} items")
                    @if (_sizeBytes > 0)
                    {
                        @($" ({FormatSize(_sizeBytes)})")
                    }
                }
                else if (!_exists)
                {
                    @("Not in OPFS")
                }
            </MudText>

            <MudDivider />

            @* Export *@
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       FullWidth="true"
                       Disabled="@(!_exists || _isEmpty || _isBusy)"
                       OnClick="ExportDatabaseAsync">
                @if (_isExporting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>Exporting...</text>
                }
                else
                {
                    <text>Export .db File</text>
                }
            </MudButton>

            @* Import *@
            <MudFileUpload T="IBrowserFile"
                           OnFilesChanged="HandleImportFileSelectedAsync"
                           Accept=".db"
                           MaximumFileCount="1"
                           Disabled="@_isBusy">
                <CustomContent Context="fileUpload">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.FileUpload"
                               FullWidth="true"
                               Disabled="@_isBusy"
                               OnClick="@fileUpload.OpenFilePickerAsync">
                        @if (_isImporting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Importing...</text>
                        }
                        else
                        {
                            <text>Import .db File</text>
                        }
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>

        </MudStack>
    </MudPaper>
</MudContainer>

<MudMessageBox @ref="_importConfirmBox" Title="Replace Database?">
    <MessageContent>
        <MudText Typo="Typo.body1" Class="mb-2">
            This will <strong>permanently replace</strong> the current database with the imported file.
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_importConfirmDetails
        </MudText>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Warning">
            Replace Database
        </MudButton>
    </YesButton>
    <CancelButton>
        <MudButton Variant="Variant.Filled" Color="Color.Default">Cancel</MudButton>
    </CancelButton>
</MudMessageBox>

@code {
    private const string DbName = "TodoDb.db";
    private const string BackupName = "TodoDb.backup.db";

    private MudMessageBox _importConfirmBox = null!;
    private string _importConfirmDetails = string.Empty;

    private bool _exists;
    private long _sizeBytes;
    private int? _itemCount;
    private bool _isExporting;
    private bool _isImporting;
    private bool _isBusy => _isExporting || _isImporting;
    private bool _isEmpty => _itemCount is null or 0;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        try
        {
            _exists = await DatabaseService.ExistsDatabaseAsync(DbName);

            if (_exists)
            {
                await using var ctx = await DbContextFactory.CreateDbContextAsync();
                _itemCount = await ctx.TodoItems.CountAsync();
            }
            else
            {
                _sizeBytes = 0;
                _itemCount = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to refresh database info");
        }
    }

    [SupportedOSPlatform("browser")]
    private async Task ExportDatabaseAsync()
    {
        _isExporting = true;
        StateHasChanged();

        try
        {
            var data = await DatabaseService.ExportDatabaseAsync(DbName);
            _sizeBytes = data.Length;

            var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
            var fileName = $"TodoDb-{timestamp}.db";

            FileOperationsInterop.DownloadMessagePackFile(new ArraySegment<byte>(data), fileName);
            Snackbar.Add($"Exported {FormatSize(data.Length)} as {fileName}", Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Export failed");
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task HandleImportFileSelectedAsync(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0)
        {
            return;
        }

        var file = e.File;

        // Read the file first so the user doesn't have to wait after confirming
        byte[] data;
        try
        {
            const long maxSize = 512 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            data = ms.ToArray();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to read import file");
            Snackbar.Add($"Failed to read file: {ex.Message}", Severity.Error);
            return;
        }

        // Show confirmation dialog when existing DB has data
        if (_exists && !_isEmpty)
        {
            _importConfirmDetails = $"\"{file.Name}\" ({FormatSize(data.Length)}) will replace " +
                                    $"TodoDb.db ({_itemCount} items).";
            StateHasChanged();

            var confirmed = await _importConfirmBox.ShowAsync();
            if (confirmed is not true)
            {
                return;
            }
        }

        _isImporting = true;
        StateHasChanged();

        var backupCreated = false;

        try
        {
            if (_exists)
            {
                // Remove old backup if it exists
                if (await DatabaseService.ExistsDatabaseAsync(BackupName))
                {
                    await DatabaseService.DeleteDatabaseAsync(BackupName);
                }

                // Close current DB, then rename to temporary backup
                await DatabaseService.CloseDatabaseAsync(DbName);
                await DatabaseService.RenameDatabaseAsync(DbName, BackupName);
                backupCreated = true;
            }
            else
            {
                await DatabaseService.CloseDatabaseAsync(DbName);
            }

            // Import raw .db file (validates SQLite header internally)
            await DatabaseService.ImportDatabaseAsync(DbName, data);

            // Validate schema on the raw imported file (no migrations - DB must match exactly)
            await ValidateSchemaAsync();

            // Schema valid - clean up temporary backup to free SAH pool slot
            if (backupCreated)
            {
                await DatabaseService.DeleteDatabaseAsync(BackupName);
            }

            await RefreshAsync();

            _sizeBytes = data.Length;
            Snackbar.Add($"Imported {FormatSize(data.Length)} from {file.Name}", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex, "Schema validation failed");
            Snackbar.Add(ex.Message, Severity.Error);
            await RestoreBackupAsync(backupCreated);
        }
        catch (ArgumentException ex)
        {
            Logger.LogWarning(ex, "Invalid file imported");
            Snackbar.Add($"Invalid file: {ex.Message}", Severity.Error);
            await RestoreBackupAsync(backupCreated);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Import failed");
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
            await RestoreBackupAsync(backupCreated);
        }
        finally
        {
            _isImporting = false;
            StateHasChanged();
        }
    }

    private async Task RestoreBackupAsync(bool backupCreated)
    {
        if (backupCreated)
        {
            try
            {
                if (await DatabaseService.ExistsDatabaseAsync(DbName))
                {
                    await DatabaseService.DeleteDatabaseAsync(DbName);
                }

                await DatabaseService.RenameDatabaseAsync(BackupName, DbName);
                Snackbar.Add("Restored original database", Severity.Info);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to restore backup");
            }
        }

    }

    private async Task ValidateSchemaAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        await ctx.ValidateSchemaAsync();
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024.0:F1} KB";
        }

        return $"{bytes / 1024.0 / 1024.0:F2} MB";
    }
}
