@using System.Net.Http.Headers
@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@using MessagePack
@using SqliteWasmBlazor
@using SqliteWasmBlazor.Components.Interop
@using SqliteWasmBlazor.Models
@using SqliteWasmBlazor.Models.DTOs
@using SqliteWasmBlazor.Models.Extensions
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IConfiguration Configuration
@inject ISqliteWasmDatabaseService DatabaseService
@inject IDbContextFactory<TodoDbContext> DbContextFactory
@inject ILogger<SeedManager> Logger

<MudPaper Elevation="2" Class="pa-4 mb-6">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Small" Class="mr-1" />
                Seed Server
            </MudText>
            <MudStack Row="true" Spacing="1">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="LoadSeedsAsync"
                           Disabled="@(_isBusy || string.IsNullOrWhiteSpace(_serverDomain))">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>

        <MudTextField @bind-Value="_serverDomain"
                      Label="Server Domain"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="e.g. seed-api.test"
                      Adornment="Adornment.Start"
                      AdornmentText="https://"
                      OnKeyUp="OnServerDomainChanged" />

        @if (string.IsNullOrWhiteSpace(_serverDomain))
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                Enter a seed server domain to connect.
            </MudAlert>
        }
        else if (_error is not null)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2">@_error</MudText>
                    <MudText Typo="Typo.caption">
                        Ensure the Seed API server is running. See
                        <MudLink Href="https://github.com/b-straub/SqliteWasmBlazor#seed-server" Target="_blank">setup instructions</MudLink>
                        for details.
                    </MudText>
                </MudStack>
            </MudAlert>
        }
        else if (_seeds is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            @* Upload current DB to server *@
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudUpload"
                           OnClick="UploadToServerAsync"
                           Disabled="@(_isBusy || _localItemCount == 0)"
                           FullWidth="true">
                    @if (_isUploading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @_statusText
                    }
                    else
                    {
                        @($"Upload Current DB ({_localItemCount:N0} items)")
                    }
                </MudButton>
                @if (_isUploading)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               OnClick="Cancel"
                               Size="Size.Small">
                        Cancel
                    </MudButton>
                }
            </MudStack>

            @if (_isBusy)
            {
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Align="Align.Center">@_statusText</MudText>
                    <MudProgressLinear Color="Color.Primary"
                                      Value="@_progress"
                                      Indeterminate="@(_progress == 0)"
                                      Size="Size.Small" />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               OnClick="Cancel"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               Size="Size.Small"
                               FullWidth="true">
                        Cancel
                    </MudButton>
                </MudStack>
            }

            @* Seeds on server *@
            @if (_seeds.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No seeds on server.</MudAlert>
            }
            else
            {
                <MudTable Items="@_seeds" Dense="true" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Records</MudTh>
                        <MudTh>Parts</MudTh>
                        <MudTh>Exported</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>@context.TotalRecordCount.ToString("N0")</MudTd>
                        <MudTd>@context.PartCount</MudTd>
                        <MudTd>@FormatDate(context.ExportedAt)</MudTd>
                        <MudTd>
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Download"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => DownloadFromServerAsync(context))"
                                               Disabled="@_isBusy" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteSeedAsync(context))"
                                               Disabled="@_isBusy" />
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </MudStack>
</MudPaper>

@code {
    private const string DatabaseName = "TodoDb.db";
    private static readonly Dictionary<string, string> TodoItemSqlTypeOverrides = new() { ["Id"] = "BLOB" };

    private string _serverDomain = string.Empty;
    private string ApiUrl => $"https://{_serverDomain}/api";
    private List<SeedInfo>? _seeds;
    private string? _error;
    private bool _isBusy;
    private bool _isUploading;
    private int _localItemCount;
    private string _statusText = string.Empty;
    private int _progress;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _serverDomain = Configuration.GetValue<string>("seedApiUrl") ?? string.Empty;

        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        _localItemCount = await ctx.TodoItems.CountAsync(t => !t.IsDeleted);

        if (!string.IsNullOrWhiteSpace(_serverDomain))
        {
            await LoadSeedsAsync();
        }
    }

    private async Task OnServerDomainChanged(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_serverDomain))
        {
            await LoadSeedsAsync();
        }
    }

    private void Cancel()
    {
        _cts?.Cancel();
    }

    // -------------------------------------------------------
    // LIST seeds from server
    // -------------------------------------------------------
    private async Task LoadSeedsAsync()
    {
        _error = null;
        _seeds = null;
        StateHasChanged();

        try
        {
            var response = await Http.GetAsync($"{ApiUrl}/seeds");

            if (!response.IsSuccessStatusCode)
            {
                _error = $"Server returned {(int)response.StatusCode} ({response.StatusCode}). Check that seedApiUrl points to a valid Seed API endpoint.";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            _seeds = JsonSerializer.Deserialize<List<SeedInfo>>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }) ?? [];
        }
        catch (HttpRequestException)
        {
            _error = $"Cannot reach seed server at {ApiUrl}. Is the server running?";
        }
        catch (Exception ex)
        {
            _error = $"Connection failed: {ex.Message}";
        }
    }

    // -------------------------------------------------------
    // UPLOAD — export current DB as multi-part seed to server
    // -------------------------------------------------------
    private async Task UploadToServerAsync()
    {
        _isBusy = true;
        _isUploading = true;
        _progress = 0;
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        StateHasChanged();

        var cancellationToken = _cts.Token;

        try
        {
            var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
            var seedName = $"todoitems-full-{timestamp}";
            var schemaHash = SchemaHashGenerator.ComputeHash<TodoItemDto>();

            var columns = MessagePackFileHeaderV2.Create<TodoItemDto>(
                tableName: "TodoItems",
                primaryKeyColumn: "Id",
                recordCount: 0,
                sqlTypeOverrides: TodoItemSqlTypeOverrides).Columns;

            var exportMetadata = new BulkExportMetadata
            {
                TableName = "TodoItems",
                Columns = columns,
                PrimaryKeyColumn = "Id",
                SchemaHash = schemaHash,
                DataType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name,
                AppIdentifier = "SqliteWasmBlazor.Demo",
                Mode = 0,
                Where = "\"IsDeleted\" = 0",
                OrderBy = "\"UpdatedAt\" DESC"
            };

            // Count items for progress
            int totalCount;
            await using (var ctx = await DbContextFactory.CreateDbContextAsync(cancellationToken))
            {
                totalCount = await ctx.TodoItems.CountAsync(t => !t.IsDeleted, cancellationToken);
            }

            var partSizeMb = Configuration.GetValue("cloudPartSizeMb", 250);
            var partSizeBytes = (long)partSizeMb * 1024 * 1024;

            // Estimate items per part from a sample export
            const int sampleSize = 1000;
            var sampleData = await DatabaseService.BulkExportAsync(DatabaseName,
                exportMetadata with { OrderBy = exportMetadata.OrderBy + $" LIMIT {sampleSize}" }, cancellationToken);
            var sampleHeader = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(sampleData);
            var partSize = sampleHeader.RecordCount > 0
                ? Math.Max(sampleSize, (int)(partSizeBytes / ((double)sampleData.Length / sampleHeader.RecordCount)))
                : 1_000_000;

            // Export and upload parts
            var parts = new List<object>();
            var totalExported = 0;
            var partIndex = 0;

            while (true)
            {
                cancellationToken.ThrowIfCancellationRequested();
                partIndex++;

                _statusText = $"Exporting part {partIndex}...";
                StateHasChanged();
                await Task.Yield();

                var partData = await DatabaseService.BulkExportAsync(DatabaseName,
                    exportMetadata with { OrderBy = exportMetadata.OrderBy + $" LIMIT {partSize} OFFSET {totalExported}" },
                    cancellationToken);
                var partHeader = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(partData);

                if (partHeader.RecordCount == 0)
                {
                    break;
                }

                totalExported += partHeader.RecordCount;

                var partFileName = $"{seedName}-part{partIndex:D3}.msgpack";

                _statusText = $"Uploading part {partIndex} ({totalExported:N0}/{totalCount:N0})...";
                _progress = totalCount > 0 ? (int)((double)totalExported / totalCount * 100) : 0;
                StateHasChanged();
                await Task.Yield();

                // Upload part to server
                using var content = new MultipartFormDataContent();
                var byteContent = new ByteArrayContent(partData);
                byteContent.Headers.ContentType = new MediaTypeHeaderValue("application/octet-stream");
                content.Add(byteContent, "file", partFileName);

                var response = await Http.PostAsync($"{ApiUrl}/seeds/{seedName}", content, cancellationToken);
                response.EnsureSuccessStatusCode();

                parts.Add(new { fileName = partFileName, recordCount = partHeader.RecordCount });

                if (partHeader.RecordCount < partSize)
                {
                    break;
                }
            }

            // Upload meta file
            _statusText = "Uploading meta file...";
            StateHasChanged();

            var meta = new
            {
                version = 2,
                magic = "SWBV2META",
                tableName = "TodoItems",
                primaryKeyColumn = "Id",
                schemaHash,
                dataType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name,
                appIdentifier = "SqliteWasmBlazor.Demo",
                exportedAt = DateTime.UtcNow.ToString("O"),
                totalRecordCount = totalExported,
                mode = 0,
                parts
            };

            var metaJson = JsonSerializer.SerializeToUtf8Bytes(meta, new JsonSerializerOptions { WriteIndented = true });
            var metaFileName = $"{seedName}.msgpack-meta";

            using var metaContent = new MultipartFormDataContent();
            var metaByteContent = new ByteArrayContent(metaJson);
            metaByteContent.Headers.ContentType = new MediaTypeHeaderValue("application/octet-stream");
            metaContent.Add(metaByteContent, "file", metaFileName);

            var metaResponse = await Http.PostAsync($"{ApiUrl}/seeds/{seedName}", metaContent, cancellationToken);
            metaResponse.EnsureSuccessStatusCode();

            _progress = 100;
            Snackbar.Add($"Uploaded {totalExported:N0} items in {parts.Count} parts to server", Severity.Success);
            await LoadSeedsAsync();
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Upload cancelled", Severity.Warning);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Upload to server failed");
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
            _isUploading = false;
            _progress = 0;
            _statusText = string.Empty;
            StateHasChanged();
        }
    }

    // -------------------------------------------------------
    // DOWNLOAD — download seed from server and import into DB
    // -------------------------------------------------------
    private async Task DownloadFromServerAsync(SeedInfo seed)
    {
        _isBusy = true;
        _progress = 0;
        _statusText = "Preparing import...";
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        StateHasChanged();

        var cancellationToken = _cts.Token;

        try
        {
            var schemaHash = SchemaHashGenerator.ComputeHash<TodoItemDto>();

            // Create temp database
            var importDbName = "TodoDb-import.db";
            if (await DatabaseService.ExistsDatabaseAsync(importDbName, cancellationToken))
            {
                await DatabaseService.DeleteDatabaseAsync(importDbName, cancellationToken);
            }

            var tempConnection = new SqliteWasmConnection($"Data Source={importDbName}");
            var optionsBuilder = new DbContextOptionsBuilder<TodoDbContext>();
            optionsBuilder.UseSqliteWasm(tempConnection);

            await using var tempCtx = new TodoDbContext(optionsBuilder.Options);
            await tempCtx.Database.MigrateAsync(cancellationToken);

            // Download and import each part file (skip meta file)
            var partFiles = seed.Files.Where(f => f.Name.EndsWith(".msgpack")).ToList();
            var totalImported = 0;
            var totalExpected = seed.TotalRecordCount;

            for (var i = 0; i < partFiles.Count; i++)
            {
                cancellationToken.ThrowIfCancellationRequested();

                var file = partFiles[i];
                _statusText = $"Downloading part {i + 1}/{partFiles.Count}...";
                StateHasChanged();
                await Task.Yield();

                // Download part from server
                var partData = await Http.GetByteArrayAsync(
                    $"{ApiUrl}/seeds/{seed.Name}/{file.Name}", cancellationToken);

                // Import into temp DB — stream raw bytes
                using var stream = new MemoryStream(partData);
                var streamReader = new MessagePackStreamReader(stream);

                var headerData = await streamReader.ReadAsync(cancellationToken);
                if (headerData is null)
                {
                    continue;
                }

                var header = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(headerData.Value);
                var expectedType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name;
                header.Validate(expectedType, schemaHash, "SqliteWasmBlazor.Demo");

                var headerBytes = MessagePackSerializer.Serialize(header);
                const int batchSize = 10000;
                using var chunkStream = new MemoryStream();
                var itemsInChunk = 0;
                chunkStream.Write(headerBytes);

                while (await streamReader.ReadAsync(cancellationToken) is { } itemBytes)
                {
                    foreach (var segment in itemBytes)
                    {
                        chunkStream.Write(segment.Span);
                    }

                    itemsInChunk++;

                    if (itemsInChunk >= batchSize)
                    {
                        await DatabaseService.BulkImportAsync(importDbName, chunkStream.ToArray(),
                            cancellationToken: cancellationToken);
                        totalImported += itemsInChunk;

                        _statusText = $"Importing {totalImported:N0} / {totalExpected:N0} items (part {i + 1}/{partFiles.Count})...";
                        _progress = totalExpected > 0 ? (int)((double)totalImported / totalExpected * 80) : 0;
                        StateHasChanged();
                        await Task.Yield();

                        chunkStream.SetLength(0);
                        chunkStream.Write(headerBytes);
                        itemsInChunk = 0;
                    }
                }

                if (itemsInChunk > 0)
                {
                    await DatabaseService.BulkImportAsync(importDbName, chunkStream.ToArray(),
                        cancellationToken: cancellationToken);
                    totalImported += itemsInChunk;

                    _statusText = $"Importing {totalImported:N0} / {totalExpected:N0} items (part {i + 1}/{partFiles.Count})...";
                    _progress = totalExpected > 0 ? (int)((double)totalImported / totalExpected * 80) : 0;
                    StateHasChanged();
                    await Task.Yield();
                }
            }

            // FTS5 rebuild
            _statusText = "Rebuilding search index...";
            _progress = 85;
            StateHasChanged();
            await Task.Yield();

            await tempCtx.RebuildTodoItemFts5IndexAsync(cancellationToken);
            await tempCtx.DisposeAsync();

            // Swap databases
            _statusText = "Swapping database...";
            _progress = 95;
            StateHasChanged();
            await Task.Yield();

            await DatabaseService.CloseDatabaseAsync(importDbName, cancellationToken);
            await DatabaseService.CloseDatabaseAsync(DatabaseName, cancellationToken);

            // Backup + swap
            var backupName = "TodoDb.bak";
            if (await DatabaseService.ExistsDatabaseAsync(backupName))
            {
                await DatabaseService.DeleteDatabaseAsync(backupName);
            }

            if (await DatabaseService.ExistsDatabaseAsync(DatabaseName))
            {
                await DatabaseService.RenameDatabaseAsync(DatabaseName, backupName);
            }

            await DatabaseService.RenameDatabaseAsync(importDbName, DatabaseName);

            _progress = 100;
            Snackbar.Add($"Imported {totalImported:N0} items from server seed", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Download cancelled", Severity.Warning);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download from server failed");
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
            _progress = 0;
            _statusText = string.Empty;
            StateHasChanged();
        }
    }

    // -------------------------------------------------------
    // DELETE seed from server
    // -------------------------------------------------------
    private async Task DeleteSeedAsync(SeedInfo seed)
    {
        _isBusy = true;
        StateHasChanged();

        try
        {
            var response = await Http.DeleteAsync($"{ApiUrl}/seeds/{seed.Name}");
            response.EnsureSuccessStatusCode();
            Snackbar.Add($"Deleted {seed.Name}", Severity.Success);
            await LoadSeedsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    private static string FormatDate(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
        {
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
        }

        return isoDate;
    }

    private class SeedInfo
    {
        public string Name { get; set; } = string.Empty;
        public string MetaFile { get; set; } = string.Empty;
        public int TotalRecordCount { get; set; }
        public string ExportedAt { get; set; } = string.Empty;
        public int PartCount { get; set; }
        public List<SeedFileInfo> Files { get; set; } = [];
    }

    private class SeedFileInfo
    {
        public string Name { get; set; } = string.Empty;
        public long Size { get; set; }
    }
}
