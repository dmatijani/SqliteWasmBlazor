@using Microsoft.EntityFrameworkCore
@using SqliteWasmBlazor
@using SqliteWasmBlazor.Models
@using SqliteWasmBlazor.Models.DTOs
@using SqliteWasmBlazor.Models.Extensions
@using SqliteWasmBlazor.Models.Enums
@using SqliteWasmBlazor.Models.Models
@using SqliteWasmBlazor.Components.Interop
@using Microsoft.AspNetCore.Components.Forms
@using System.Runtime.Versioning
@using System.Diagnostics
@using MessagePack
@inject IDbContextFactory<TodoDbContext> DbContextFactory
@inject ISnackbar Snackbar
@inject ILogger<TodoImportExport> Logger
@inject ISqliteWasmDatabaseService DatabaseService
@inject IConfiguration Configuration
@implements IAsyncDisposable

<MudPaper Elevation="2" Class="pa-4 mb-6">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.ImportExport" Size="Size.Small" Class="mr-1" />
                Database Import/Export
            </MudText>
            <MudButtonGroup Size="Size.Small" OverrideStyles="false">
                <MudButton OnClick="@(() => SetExportMode(ExportMode.Full))"
                          Color="@(_exportMode == ExportMode.Full ? Color.Primary : Color.Default)"
                          Variant="@(_exportMode == ExportMode.Full ? Variant.Filled : Variant.Outlined)">
                    Full
                </MudButton>
                <MudButton OnClick="@(() => SetExportMode(ExportMode.Delta))"
                          Color="@(_exportMode == ExportMode.Delta ? Color.Primary : Color.Default)"
                          Variant="@(_exportMode == ExportMode.Delta ? Variant.Filled : Variant.Outlined)">
                    Delta
                </MudButton>
            </MudButtonGroup>
        </MudStack>

        @if (_exportMode == ExportMode.Delta)
        {
            <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background-color: var(--mud-palette-info);">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2">Delta Export Info</MudText>
                    <MudText Typo="Typo.body2">
                        Exports only items changed since last delta export (including soft-deleted items for sync).
                    </MudText>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="pa-3" Style="background-color: var(--mud-palette-background-grey);">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2">Conflict Resolution Strategy</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Choose how to handle conflicts when importing delta data with existing local changes
                    </MudText>
                    <MudRadioGroup @bind-Value="_conflictResolution">
                        <MudRadio T="ConflictResolutionStrategy" Value="ConflictResolutionStrategy.LastWriteWins" Color="Color.Primary">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2"><strong>Last Write Wins</strong></MudText>
                                <MudText Typo="Typo.caption">Most recent timestamp wins (compares UpdatedAt)</MudText>
                            </MudStack>
                        </MudRadio>
                        <MudRadio T="ConflictResolutionStrategy" Value="ConflictResolutionStrategy.LocalWins" Color="Color.Success">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2"><strong>Local Wins</strong></MudText>
                                <MudText Typo="Typo.caption">Keep local changes, only add new items from import</MudText>
                            </MudStack>
                        </MudRadio>
                        <MudRadio T="ConflictResolutionStrategy" Value="ConflictResolutionStrategy.DeltaWins" Color="Color.Warning">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2"><strong>Delta Wins</strong></MudText>
                                <MudText Typo="Typo.caption">Accept all imported changes, overwrite local items</MudText>
                            </MudStack>
                        </MudRadio>
                    </MudRadioGroup>
                </MudStack>
            </MudPaper>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                @if (_isExporting)
                {
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Align="Align.Center">
                            @_exportStatus
                        </MudText>
                        <MudProgressLinear Color="Color.Primary"
                                          Value="@(_exportProgress)"
                                          Indeterminate="@(_exportProgress == 0)"
                                          Size="Size.Large" />
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   OnClick="CancelExport"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   Size="Size.Small"
                                   FullWidth="true">
                            Cancel
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ExportAsync"
                               StartIcon="@Icons.Material.Filled.Download"
                               FullWidth="true">
                        <MudText>@GetExportButtonText()</MudText>
                    </MudButton>
                }
            </MudItem>

            <MudItem xs="12" sm="6">
                @if (_isWaitingForParts || _isImporting && _pendingMeta is not null)
                {
                    <div style="@(_isImporting ? "display:none" : "")">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption">Select @_requiredParts.Count part file(s):</MudText>
                            @foreach (var part in _requiredParts)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@part</MudText>
                            }
                            <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                                           OnFilesChanged="ImportPartsAsync"
                                           Accept=".msgpack"
                                           MaximumFileCount="@Math.Max(_requiredParts.Count, 1)">
                                <CustomContent Context="fileUpload">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.CloudUpload"
                                               OnClick="@fileUpload.OpenFilePickerAsync"
                                               FullWidth="true">
                                        Select Part Files
                                    </MudButton>
                                </CustomContent>
                            </MudFileUpload>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       OnClick="CancelMultiPartImport"
                                       Size="Size.Small"
                                       FullWidth="true">
                                Cancel
                            </MudButton>
                        </MudStack>
                    </div>
                }
                else
                {
                    <div style="@(_isImporting ? "display:none" : "")">
                        <MudFileUpload T="IBrowserFile"
                                       OnFilesChanged="ImportAsync"
                                       Accept=".msgpack,.msgpack-meta"
                                       MaximumFileCount="1">
                            <CustomContent Context="fileUpload">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.CloudUpload"
                                           OnClick="@fileUpload.OpenFilePickerAsync"
                                           FullWidth="true">
                                    <MudText>@GetImportButtonText()</MudText>
                                </MudButton>
                            </CustomContent>
                        </MudFileUpload>
                    </div>
                }
                @if (_isImporting)
                {
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body2" Align="Align.Center">
                            @if (_isFinalizing)
                            {
                                @:Rebuilding search index...
                            }
                            else
                            {
                                @($"{_importProgress:N0} / {_importTotal:N0} items")
                            }
                        </MudText>
                        <MudProgressLinear Color="@(_isFinalizing ? Color.Success : Color.Primary)"
                                          Value="@(_importTotal > 0 ? (double)_importProgress / _importTotal * 100 : 0)"
                                          Indeterminate="@_isFinalizing"
                                          Size="Size.Large" />
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   OnClick="CancelImport"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   FullWidth="true">
                            Cancel
                        </MudButton>
                    </MudStack>
                }
            </MudItem>
        </MudGrid>

        <MudAlert Severity="@GetAlertSeverity()" Dense="true" NoIcon="false">
            @GetModeDescription()
        </MudAlert>

        @if (_showTombstoneCleanup && _tombstoneCount > 0)
        {
            <MudPaper Elevation="0" Class="pa-3" Style="background-color: var(--mud-palette-success);">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle2">Delta Sync Complete!</MudText>
                        <MudText Typo="Typo.body2">
                            @_tombstoneCount soft-deleted item(s) ready for cleanup.
                        </MudText>
                    </MudStack>
                    <MudButton Color="Color.Success"
                              Variant="Variant.Filled"
                              OnClick="@CleanTombstonesAsync"
                              StartIcon="@Icons.Material.Filled.CleaningServices">
                        Clean Tombstones
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudPaper>

@code {
    /// <summary>
    /// Database filename (without path) - e.g., "TodoDb.db"
    /// </summary>
    [Parameter]
    public string DatabaseName { get; set; } = "TodoDb.db";

    [Parameter]
    public EventCallback OnDataChanged { get; set; }

    /// <summary>
    /// Application identifier to prevent cross-app data imports
    /// </summary>
    private const string AppIdentifier = "SqliteWasmBlazor.Demo";

    /// <summary>
    /// TodoItem.Id uses [Column(TypeName="BLOB")] — override the EF Core default (TEXT) for Guid
    /// </summary>
    private static readonly Dictionary<string, string> TodoItemSqlTypeOverrides = new() { ["Id"] = "BLOB" };

    /// <summary>
    /// Schema hash computed from TodoItemDto structure (automatic validation)
    /// </summary>
    private readonly string _schemaHash = SqliteWasmBlazor.Components.Interop.SchemaHashGenerator.ComputeHash<TodoItemDto>();

    private TodoDbContext? _tempDbContext;
    private ExportMode _exportMode = ExportMode.Full;
    private ConflictResolutionStrategy _conflictResolution = ConflictResolutionStrategy.LastWriteWins;
    private bool _showTombstoneCleanup;
    private int _tombstoneCount;
    private bool _isExporting;
    private bool _isImporting;
    private bool _isFinalizing;
    private int _importProgress;
    private int _importTotal;
    private int _exportProgress;
    private string _exportStatus = string.Empty;
    private CancellationTokenSource? _exportCts;
    private CancellationTokenSource? _importCts;

    // Multi-part import state
    private bool _isWaitingForParts;
    private System.Text.Json.JsonElement? _pendingMeta;
    private List<string> _requiredParts = [];

    private string ImportDatabaseName => $"{Path.GetFileNameWithoutExtension(DatabaseName)}-import{Path.GetExtension(DatabaseName)}";
    private string BackupDatabaseName => $"{Path.GetFileNameWithoutExtension(DatabaseName)}.bak";

    private void SetExportMode(ExportMode mode)
    {
        _exportMode = mode;
        _showTombstoneCleanup = false; // Reset cleanup banner when switching modes
        StateHasChanged();
    }

    private string GetExportButtonText()
    {
        return _exportMode == ExportMode.Full
            ? "Export All TodoItems"
            : "Export Delta (Changed Items)";
    }

    private string GetImportButtonText()
    {
        return _exportMode == ExportMode.Full
            ? "Import TodoItems (Replace All)"
            : "Import Delta (Merge/Update)";
    }

    private Severity GetAlertSeverity()
    {
        return _exportMode == ExportMode.Full ? Severity.Warning : Severity.Info;
    }

    private string GetModeDescription()
    {
        if (_exportMode == ExportMode.Full)
        {
            return "Full mode: Import will create a temporary database and swap it after validation. Your current data will be backed up as " + BackupDatabaseName;
        }
        else
        {
            var strategyDesc = _conflictResolution switch
            {
                ConflictResolutionStrategy.LastWriteWins => "Most recent changes win (compares timestamps)",
                ConflictResolutionStrategy.LocalWins => "Local changes always win (only new items are added)",
                ConflictResolutionStrategy.DeltaWins => "Imported changes always win (local items overwritten)",
                _ => ""
            };
            return $"Delta mode: Import will merge/update items. Conflict resolution: {strategyDesc}";
        }
    }

    // Export methods (V2 — worker-side bulk export)
    private async Task ExportAsync()
    {
        if (_isExporting)
        {
            return;
        }

        _isExporting = true;
        _exportCts?.Dispose();
        _exportCts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            var sw = Stopwatch.StartNew();
            var cancellationToken = _exportCts.Token;

            // Build WHERE clause for delta export
            string? where = null;
            string[]? whereParams = null;

            if (_exportMode == ExportMode.Delta)
            {
                await using var ctx = await DbContextFactory.CreateDbContextAsync(cancellationToken);
                var latestCheckpoint = await ctx.SyncState
                    .OrderByDescending(s => s.Id)
                    .FirstOrDefaultAsync(cancellationToken);
                var lastExportAt = latestCheckpoint?.CreatedAt ?? DateTime.MinValue;
                var lastExportAtStr = lastExportAt.ToString("O");

                // Include changed non-deleted + soft-deleted since checkpoint
                where = "(\"UpdatedAt\" > $0 AND \"IsDeleted\" = 0) OR (\"IsDeleted\" = 1 AND \"DeletedAt\" > $0)";
                whereParams = [lastExportAtStr];
            }
            else
            {
                where = "\"IsDeleted\" = 0";
            }

            var columns = MessagePackFileHeaderV2.Create<TodoItemDto>(
                tableName: "TodoItems",
                primaryKeyColumn: "Id",
                recordCount: 0,
                sqlTypeOverrides: TodoItemSqlTypeOverrides).Columns;

            var exportMetadata = new BulkExportMetadata
            {
                TableName = "TodoItems",
                Columns = columns,
                PrimaryKeyColumn = "Id",
                SchemaHash = _schemaHash,
                DataType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name,
                AppIdentifier = AppIdentifier,
                Mode = _exportMode == ExportMode.Full ? 0 : 1,
                Where = where,
                WhereParams = whereParams,
                OrderBy = "\"UpdatedAt\" DESC"
            };

            var partSizeMb = Configuration.GetValue("exportPartSizeMb", 250);
            var partSizeBytes = (long)partSizeMb * 1024 * 1024;

            // Estimate items per part: export a small sample to measure avg bytes per item
            const int sampleSize = 1000;
            var sampleData = await DatabaseService.BulkExportAsync(DatabaseName,
                exportMetadata with { OrderBy = exportMetadata.OrderBy + $" LIMIT {sampleSize}" }, cancellationToken);
            var sampleHeader = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(sampleData);
            var sampleCount = sampleHeader.RecordCount;

            int partSize;
            if (sampleCount > 0)
            {
                var avgBytesPerItem = (double)sampleData.Length / sampleCount;
                partSize = Math.Max(sampleSize, (int)(partSizeBytes / avgBytesPerItem));
                Logger.LogInformation("Export: ~{BytesPerItem:F0} bytes/item, {PartSize:N0} items per {Mb}MB part",
                    avgBytesPerItem, partSize, partSizeMb);
            }
            else
            {
                partSize = 1_000_000; // Fallback
            }
            var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
            var prefix = _exportMode == ExportMode.Full ? "todoitems-full" : "todoitems-delta";

            _exportStatus = "Counting records...";
            _exportProgress = 0;
            StateHasChanged();
            await Task.Yield();

            // Get total count for progress calculation
            int totalItemCount;
            await using (var countCtx = await DbContextFactory.CreateDbContextAsync(cancellationToken))
            {
                if (_exportMode == ExportMode.Delta)
                {
                    var latestCp = await countCtx.SyncState
                        .OrderByDescending(s => s.Id)
                        .FirstOrDefaultAsync(cancellationToken);
                    var lastAt = latestCp?.CreatedAt ?? DateTime.MinValue;
                    totalItemCount = await countCtx.TodoItems.CountAsync(t =>
                        (t.UpdatedAt > lastAt && !t.IsDeleted) ||
                        (t.IsDeleted && t.DeletedAt > lastAt), cancellationToken);
                }
                else
                {
                    totalItemCount = await countCtx.TodoItems.CountAsync(t => !t.IsDeleted, cancellationToken);
                }
            }

            _exportStatus = $"Exporting {totalItemCount:N0} records...";
            StateHasChanged();

            var parts = new List<(string fileName, int recordCount)>();
            var totalExported = 0;
            var partIndex = 0;

            while (true)
            {
                cancellationToken.ThrowIfCancellationRequested();
                partIndex++;

                _exportStatus = $"Exporting part {partIndex} ({totalExported:N0} / {totalItemCount:N0})...";
                StateHasChanged();
                await Task.Yield();

                var partData = await DatabaseService.BulkExportAsync(DatabaseName,
                    exportMetadata with { OrderBy = exportMetadata.OrderBy + $" LIMIT {partSize} OFFSET {totalExported}" },
                    cancellationToken);
                var partHeader = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(partData);

                if (partHeader.RecordCount == 0)
                {
                    break;
                }

                totalExported += partHeader.RecordCount;

                if (partHeader.RecordCount < partSize && parts.Count == 0)
                {
                    // Small export — single file, no multi-part needed
                    var singleFileName = $"{prefix}-{timestamp}.msgpack";
                    FileOperationsInterop.DownloadMessagePackFile(new ArraySegment<byte>(partData), singleFileName);
                    break;
                }

                // Multi-part: download this part
                var partFileName = $"{prefix}-{timestamp}-part{partIndex:D3}.msgpack";
                FileOperationsInterop.DownloadMessagePackFile(new ArraySegment<byte>(partData), partFileName);
                parts.Add((partFileName, partHeader.RecordCount));

                _exportStatus = $"Exported {totalExported:N0} / {totalItemCount:N0} records (part {partIndex})...";
                _exportProgress = totalItemCount > 0 ? (int)((double)totalExported / totalItemCount * 100) : 0;
                StateHasChanged();
                await Task.Yield();

                if (partHeader.RecordCount < partSize)
                {
                    break; // Last part
                }
            }

            // If multi-part, download the meta file
            if (parts.Count > 0)
            {
                var meta = new
                {
                    version = 2,
                    magic = "SWBV2META",
                    tableName = "TodoItems",
                    primaryKeyColumn = "Id",
                    schemaHash = _schemaHash,
                    dataType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name,
                    appIdentifier = AppIdentifier,
                    exportedAt = DateTime.UtcNow.ToString("O"),
                    totalRecordCount = totalExported,
                    mode = _exportMode == ExportMode.Full ? 0 : 1,
                    parts = parts.Select(p => new { fileName = p.fileName, recordCount = p.recordCount }).ToArray()
                };

                var metaJson = System.Text.Json.JsonSerializer.SerializeToUtf8Bytes(meta,
                    new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

                var metaFileName = $"{prefix}-{timestamp}.msgpack-meta";
                FileOperationsInterop.DownloadMessagePackFile(new ArraySegment<byte>(metaJson), metaFileName);

                _exportStatus = $"Done — {totalExported:N0} records in {parts.Count} parts";
            }

            sw.Stop();
            var count = totalExported;

            Logger.LogInformation("V2 export completed: {Count} records in {Ms}ms ({Parts} parts)",
                count, sw.ElapsedMilliseconds, Math.Max(parts.Count, 1));

            // Create checkpoint after delta export
            if (_exportMode == ExportMode.Delta && count > 0)
            {
                try
                {
                    await using var context = await DbContextFactory.CreateDbContextAsync(cancellationToken);
                    var checkpoint = await context.CreateCheckpointAsync(
                        $"Auto checkpoint after delta export ({count} items)", cancellationToken: cancellationToken);

                    _tombstoneCount = checkpoint.TombstoneCount;
                    if (_tombstoneCount > 0)
                    {
                        _showTombstoneCleanup = true;
                    }

                    await OnDataChanged.InvokeAsync();
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to create checkpoint after delta export");
                    Snackbar.Add("Warning: Failed to create checkpoint", Severity.Warning);
                }
            }

            Snackbar.Add($"Exported {count:N0} records in {sw.ElapsedMilliseconds}ms", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            Logger.LogInformation("Export cancelled");
            Snackbar.Add("Export cancelled", Severity.Warning);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Export failed");
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private void CancelExport()
    {
        _exportCts?.Cancel();
    }

    private string GetExportFileName()
    {
        var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        var prefix = _exportMode == ExportMode.Full ? "todoitems-full" : "todoitems-delta";
        return $"{prefix}-{timestamp}.msgpack";
    }

    // Import (V2 — streaming batches to worker)
    private async Task ImportAsync(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || _isImporting)
        {
            return;
        }

        var file = e.File;

        // Detect meta file → switch to multi-part import
        if (file.Name.EndsWith(".msgpack-meta", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                await using var metaStream = file.OpenReadStream(1024 * 1024); // 1MB max for meta
                using var ms = new MemoryStream();
                await metaStream.CopyToAsync(ms);
                var meta = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(ms.ToArray());

                if (meta.GetProperty("magic").GetString() != "SWBV2META")
                {
                    Snackbar.Add("Invalid meta file", Severity.Error);
                    return;
                }

                _pendingMeta = meta;
                _requiredParts = meta.GetProperty("parts").EnumerateArray()
                    .Select(p => p.GetProperty("fileName").GetString()!)
                    .ToList();
                _isWaitingForParts = true;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to read meta file: {ex.Message}", Severity.Error);
            }

            return;
        }

        _isImporting = true;
        _importProgress = 0;
        _importTotal = 0;
        _importCts?.Dispose();
        _importCts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            var sw = Stopwatch.StartNew();
            var cancellationToken = _importCts.Token;

            Logger.LogInformation("Import started: {FileName} ({Size} bytes)", file.Name, file.Size);

            const int batchSize = 10000;
            const long maxFileSize = 1024L * 1024L * 500L;

            var conflictStrategy = _exportMode == ExportMode.Delta
                ? _conflictResolution
                : ConflictResolutionStrategy.None;

            var dbName = _exportMode == ExportMode.Full ? ImportDatabaseName : DatabaseName;

            // Full mode: create temp database with migrations first
            if (_exportMode == ExportMode.Full)
            {
                if (await DatabaseService.ExistsDatabaseAsync(ImportDatabaseName, cancellationToken))
                {
                    await DatabaseService.DeleteDatabaseAsync(ImportDatabaseName, cancellationToken);
                }

                var tempConnection = new SqliteWasmConnection($"Data Source={ImportDatabaseName}");
                var optionsBuilder = new DbContextOptionsBuilder<TodoDbContext>();
                optionsBuilder.UseSqliteWasm(tempConnection);

                _tempDbContext = new TodoDbContext(optionsBuilder.Options);
                await _tempDbContext.Database.MigrateAsync(cancellationToken);
            }

            // Stream raw MessagePack bytes — no item deserialization in C#
            await using var fileStream = file.OpenReadStream(maxFileSize);
            var streamReader = new MessagePackStreamReader(fileStream);

            // Read and validate V2 header (only deserialization in entire import)
            var headerData = await streamReader.ReadAsync(cancellationToken);
            if (headerData is null)
            {
                throw new InvalidOperationException("Empty file or missing header");
            }

            var headerSequence = headerData.Value;
            var header = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(headerSequence);
            var expectedType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name;
            header.Validate(expectedType, _schemaHash, AppIdentifier);

            _importTotal = header.RecordCount;
            _importProgress = 0;

            Logger.LogInformation("Importing {Count} items from V2 file (table: {Table})",
                header.RecordCount, header.TableName);

            // Serialize header once for reuse in chunk payloads
            var headerBytes = MessagePackSerializer.Serialize(header);

            // Stream raw item bytes in chunks — C# never deserializes item content
            var totalCount = 0;
            using var chunkStream = new MemoryStream();
            var itemsInChunk = 0;

            chunkStream.Write(headerBytes);

            while (await streamReader.ReadAsync(cancellationToken) is { } itemBytes)
            {
                // Copy raw MessagePack bytes without deserialization
                foreach (var segment in itemBytes)
                {
                    chunkStream.Write(segment.Span);
                }

                itemsInChunk++;

                if (itemsInChunk >= batchSize)
                {
                    await DatabaseService.BulkImportAsync(dbName, chunkStream.ToArray(), conflictStrategy, cancellationToken);
                    totalCount += itemsInChunk;

                    _importProgress = totalCount;
                    Logger.LogDebug("Import progress: {Count}/{Total} items", totalCount, header.RecordCount);

                    // Reset chunk, write header for next batch
                    chunkStream.SetLength(0);
                    chunkStream.Write(headerBytes);
                    itemsInChunk = 0;

                    StateHasChanged();
                    await Task.Yield();
                }
            }

            // Final chunk
            if (itemsInChunk > 0)
            {
                await DatabaseService.BulkImportAsync(dbName, chunkStream.ToArray(), conflictStrategy, cancellationToken);
                totalCount += itemsInChunk;
            }

            // Post-import: finalize based on mode
            if (_exportMode == ExportMode.Delta)
            {
                await using var ctx = await DbContextFactory.CreateDbContextAsync(cancellationToken);
                _tombstoneCount = await ctx.TodoItems.CountAsync(t => t.IsDeleted, cancellationToken);
                if (_tombstoneCount > 0)
                {
                    _showTombstoneCleanup = true;
                }

                await ctx.CreateCheckpointAsync(
                    $"Auto checkpoint after delta import ({totalCount} items)",
                    cancellationToken: cancellationToken);
            }
            else
            {
                // Full: FTS5 rebuild + DB swap
                if (_tempDbContext is not null)
                {
                    _importProgress = totalCount;
                    _importTotal = totalCount;
                    _isFinalizing = true;
                    StateHasChanged();
                    await Task.Yield();

                    await _tempDbContext.RebuildTodoItemFts5IndexAsync(cancellationToken);
                    await _tempDbContext.DisposeAsync();
                    _tempDbContext = null;
                }

                Snackbar.Add("Swapping database...", Severity.Info);
                StateHasChanged();
                await Task.Yield();

                await DatabaseService.CloseDatabaseAsync(ImportDatabaseName, cancellationToken);
                await DatabaseService.CloseDatabaseAsync(DatabaseName, cancellationToken);
                await SwapDatabasesAsync(DatabaseName, ImportDatabaseName, BackupDatabaseName, DatabaseService, Logger);

                await using var newCtx = await DbContextFactory.CreateDbContextAsync(cancellationToken);
                await newCtx.CreateCheckpointAsync(
                    $"Auto checkpoint after full import ({totalCount} items)",
                    cancellationToken: cancellationToken);
            }

            sw.Stop();
            Logger.LogInformation("Import completed: {Count} items in {Ms}ms", totalCount, sw.ElapsedMilliseconds);
            Snackbar.Add($"Imported {totalCount:N0} items in {sw.ElapsedMilliseconds}ms", Severity.Success);
            await OnDataChanged.InvokeAsync();
        }
        catch (OperationCanceledException)
        {
            Logger.LogInformation("Import cancelled");
            Snackbar.Add("Import cancelled", Severity.Warning);
            await CleanupTempDatabaseAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Import failed");
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
            await CleanupTempDatabaseAsync();
        }
        finally
        {
            _isImporting = false;
            _isFinalizing = false;
            StateHasChanged();
        }
    }

    private void CancelImport()
    {
        _importCts?.Cancel();
    }

    private void CancelMultiPartImport()
    {
        _isWaitingForParts = false;
        _pendingMeta = null;
        _requiredParts = [];
        StateHasChanged();
    }

    private async Task ImportPartsAsync(InputFileChangeEventArgs e)
    {
        if (_pendingMeta is null || e.FileCount == 0)
        {
            return;
        }

        var meta = _pendingMeta.Value;
        var files = e.GetMultipleFiles(_requiredParts.Count);

        // Validate all required parts are present
        var filesByName = files.ToDictionary(f => f.Name, f => f);
        var missing = _requiredParts.Where(name => !filesByName.ContainsKey(name)).ToList();

        if (missing.Count > 0)
        {
            Snackbar.Add($"Missing part files: {string.Join(", ", missing)}", Severity.Error);
            return;
        }

        _isImporting = true;
        _importProgress = 0;
        _importTotal = _pendingMeta.Value.GetProperty("totalRecordCount").GetInt32();
        _importCts?.Dispose();
        _importCts = new CancellationTokenSource();
        StateHasChanged();

        var cancellationToken = _importCts.Token;

        try
        {
            var sw = Stopwatch.StartNew();
            var totalCount = 0;
            var totalParts = _requiredParts.Count;

            // Full mode: create temp database
            if (_exportMode == ExportMode.Full)
            {
                if (await DatabaseService.ExistsDatabaseAsync(ImportDatabaseName, cancellationToken))
                {
                    await DatabaseService.DeleteDatabaseAsync(ImportDatabaseName, cancellationToken);
                }

                var tempConnection = new SqliteWasmConnection($"Data Source={ImportDatabaseName}");
                var optionsBuilder = new DbContextOptionsBuilder<TodoDbContext>();
                optionsBuilder.UseSqliteWasm(tempConnection);

                _tempDbContext = new TodoDbContext(optionsBuilder.Options);
                await _tempDbContext.Database.MigrateAsync(cancellationToken);
            }

            var dbName = _exportMode == ExportMode.Full ? ImportDatabaseName : DatabaseName;
            var conflictStrategy = _exportMode == ExportMode.Delta
                ? _conflictResolution
                : ConflictResolutionStrategy.None;

            // Import each part sequentially using existing raw byte streaming
            for (var i = 0; i < _requiredParts.Count; i++)
            {
                cancellationToken.ThrowIfCancellationRequested();

                var partFile = filesByName[_requiredParts[i]];
                _importProgress = totalCount;
                _importTotal = meta.GetProperty("totalRecordCount").GetInt32();

                Logger.LogInformation("Importing part {Part}/{Total}: {FileName}", i + 1, totalParts, partFile.Name);

                // Stream raw bytes from part file to worker (same as single file import)
                await using var fileStream = partFile.OpenReadStream(1024L * 1024L * 500L);
                var streamReader = new MessagePackStreamReader(fileStream);

                var headerData = await streamReader.ReadAsync(cancellationToken);
                if (headerData is null)
                {
                    throw new InvalidOperationException($"Empty part file: {partFile.Name}");
                }

                var headerSequence = headerData.Value;
                var header = MessagePackSerializer.Deserialize<MessagePackFileHeaderV2>(headerSequence);
                var expectedType = typeof(TodoItemDto).FullName ?? typeof(TodoItemDto).Name;
                header.Validate(expectedType, _schemaHash, AppIdentifier);

                var headerBytes = MessagePackSerializer.Serialize(header);

                // Stream in chunks
                const int batchSize = 10000;
                using var chunkStream = new MemoryStream();
                var itemsInChunk = 0;
                chunkStream.Write(headerBytes);

                while (await streamReader.ReadAsync(cancellationToken) is { } itemBytes)
                {
                    foreach (var segment in itemBytes)
                    {
                        chunkStream.Write(segment.Span);
                    }

                    itemsInChunk++;

                    if (itemsInChunk >= batchSize)
                    {
                        await DatabaseService.BulkImportAsync(dbName, chunkStream.ToArray(), conflictStrategy, cancellationToken);
                        totalCount += itemsInChunk;
                        _importProgress = totalCount;

                        chunkStream.SetLength(0);
                        chunkStream.Write(headerBytes);
                        itemsInChunk = 0;

                        StateHasChanged();
                        await Task.Yield();
                    }
                }

                if (itemsInChunk > 0)
                {
                    await DatabaseService.BulkImportAsync(dbName, chunkStream.ToArray(), conflictStrategy, cancellationToken);
                    totalCount += itemsInChunk;
                    _importProgress = totalCount;
                }

                StateHasChanged();
                await Task.Yield();
            }

            // Post-import finalize (same as single file)
            if (_exportMode == ExportMode.Delta)
            {
                await using var ctx = await DbContextFactory.CreateDbContextAsync(cancellationToken);
                _tombstoneCount = await ctx.TodoItems.CountAsync(t => t.IsDeleted, cancellationToken);
                if (_tombstoneCount > 0)
                {
                    _showTombstoneCleanup = true;
                }

                await ctx.CreateCheckpointAsync(
                    $"Auto checkpoint after multi-part delta import ({totalCount} items)",
                    cancellationToken: cancellationToken);
            }
            else
            {
                if (_tempDbContext is not null)
                {
                    _isFinalizing = true;
                    StateHasChanged();
                    await Task.Yield();

                    await _tempDbContext.RebuildTodoItemFts5IndexAsync(cancellationToken);
                    await _tempDbContext.DisposeAsync();
                    _tempDbContext = null;
                }

                Snackbar.Add("Swapping database...", Severity.Info);
                StateHasChanged();
                await Task.Yield();

                await DatabaseService.CloseDatabaseAsync(ImportDatabaseName, cancellationToken);
                await DatabaseService.CloseDatabaseAsync(DatabaseName, cancellationToken);
                await SwapDatabasesAsync(DatabaseName, ImportDatabaseName, BackupDatabaseName, DatabaseService, Logger);

                await using var newCtx = await DbContextFactory.CreateDbContextAsync(cancellationToken);
                await newCtx.CreateCheckpointAsync(
                    $"Auto checkpoint after multi-part full import ({totalCount} items)",
                    cancellationToken: cancellationToken);
            }

            sw.Stop();
            Snackbar.Add($"Imported {totalCount:N0} items from {totalParts} parts in {sw.ElapsedMilliseconds}ms", Severity.Success);
            await OnDataChanged.InvokeAsync();
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Multi-part import cancelled", Severity.Warning);
            await CleanupTempDatabaseAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Multi-part import failed");
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
            await CleanupTempDatabaseAsync();
        }
        finally
        {
            _isImporting = false;
            _isFinalizing = false;
            _isWaitingForParts = false;
            _pendingMeta = null;
            _requiredParts = [];
            StateHasChanged();
        }
    }

    private async Task CleanupTempDatabaseAsync()
    {
        if (_tempDbContext is not null)
        {
            await _tempDbContext.DisposeAsync();
            _tempDbContext = null;
        }

        try
        {
            if (await DatabaseService.ExistsDatabaseAsync(ImportDatabaseName))
            {
                await DatabaseService.DeleteDatabaseAsync(ImportDatabaseName);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Cleanup of temp database failed");
        }
    }


    [SupportedOSPlatform("browser")]
    private static async Task SwapDatabasesAsync(string mainDbName, string importDbName, string backupDbName, ISqliteWasmDatabaseService databaseService, ILogger logger)
    {
        // Atomic file swap using OPFS operations:
        // 1. Delete old backup if exists
        // 2. Delete current db (or rename to backup if needed)
        // 3. Rename import db -> current

        try
        {
            var bridge = databaseService;

            // Step 1: Delete old backup if it exists
            if (await bridge.ExistsDatabaseAsync(backupDbName))
            {
                logger.LogDebug("Deleting old backup database: {BackupDatabase}", backupDbName);
                await bridge.DeleteDatabaseAsync(backupDbName);
            }

            // Step 2: Check if main database exists in OPFS
            // Note: The main database might not exist in OPFS if it was only used by EF Core
            var mainDbExists = await bridge.ExistsDatabaseAsync(mainDbName);
            logger.LogDebug("Main database exists in OPFS: {Exists}", mainDbExists);

            if (mainDbExists)
            {
                // Rename current database to backup for safety
                logger.LogDebug("Renaming current database to backup: {MainDatabase} → {BackupDatabase}", mainDbName, backupDbName);
                await bridge.RenameDatabaseAsync(mainDbName, backupDbName);
            }
            else
            {
                // Main database doesn't exist in OPFS yet (created by import/initial setup)
                logger.LogDebug("Main database doesn't exist in OPFS, will be created by import");
            }

            // Step 3: Rename import database to main
            logger.LogDebug("Renaming import database to main: {ImportDatabase} → {MainDatabase}", importDbName, mainDbName);
            await bridge.RenameDatabaseAsync(importDbName, mainDbName);

            logger.LogInformation("Database swap completed: {MainDatabase} is now active{Backup}",
                mainDbName,
                mainDbExists ? $", backup saved as {backupDbName}" : "");
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Database swap failed");
            throw new InvalidOperationException($"Failed to swap databases. Your data may still be in the import database ({importDbName}).", ex);
        }
    }

    /// <summary>
    /// Permanently removes soft-deleted items (tombstones) from the database.
    /// Should only be called after successful delta export to ensure deleted items are synced.
    /// </summary>
    private async Task CleanTombstonesAsync()
    {
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            // Get all soft-deleted items
            var tombstones = await context.TodoItems
                .Where(t => t.IsDeleted)
                .ToListAsync();

            if (tombstones.Count == 0)
            {
                Snackbar.Add("No tombstones found to clean", Severity.Info);
                _showTombstoneCleanup = false;
                _tombstoneCount = 0;
                return;
            }

            var count = tombstones.Count;

            // Permanently delete tombstones
            context.TodoItems.RemoveRange(tombstones);
            await context.SaveChangesAsync();

            Logger.LogInformation("Cleaned {Count} tombstones from database", count);
            Snackbar.Add($"Successfully removed {count:N0} tombstone(s)", Severity.Success);

            // Hide cleanup banner
            _showTombstoneCleanup = false;
            _tombstoneCount = 0;

            // Trigger data refresh to update UI
            await OnDataChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to clean tombstones");
            Snackbar.Add($"Failed to clean tombstones: {ex.Message}", Severity.Error);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_tempDbContext is not null)
        {
            await _tempDbContext.DisposeAsync();
        }

        _exportCts?.Dispose();
        _importCts?.Dispose();
    }
}
